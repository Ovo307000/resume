import React, { useState, useEffect } from 'react';
import {
  AppBar,
  Toolbar,
  Box,
  Button,
  IconButton,
  Drawer,
  List,
  ListItem,
  ListItemButton,
  ListItemText,
  useScrollTrigger,
  Container,
  Divider,
  alpha,
  useTheme as useMuiTheme
} from '@mui/material';
import { FiMenu, FiX } from 'react-icons/fi';
import { useLocation, Link, useNavigate } from 'react-router-dom';
import { useTranslation } from 'react-i18next';
import { motion, AnimatePresence } from 'framer-motion';
import { useTheme } from '../../contexts/ThemeContext';
import ThemeToggle from '../ui/theme/ThemeToggle';
import LanguageSelector from '../ui/language/LanguageSelector';
import Logo from '../ui/Logo';

// 从JSON数据导入导航项
import resumeData from '../../data/resumeData.json';

interface NavRoute {
  path: string;
  label: string;
}

/**
 * 导航链接组件
 */
const NavLink: React.FC<{ route: NavRoute; active: boolean }> = ({ route, active }) => {
  const { theme } = useTheme();
  const muiTheme = useMuiTheme();
  const navigate = useNavigate();

  // 处理点击跳转
  const handleClick = (e: React.MouseEvent) => {
    e.preventDefault();
    navigate(route.path);
  };

  return (
    <Box sx={{ position: 'relative' }}>
      <Button
        component={Link}
        to={route.path}
        onClick={handleClick}
        sx={{
          color: active ? 'primary.main' : 'text.primary',
          mx: 1.5,
          py: 1.5,
          fontWeight: 500,
          letterSpacing: '0.3px',
          fontSize: '0.95rem',
          textTransform: 'none',
          '&:hover': {
            backgroundColor: 'transparent',
            color: 'primary.main',
          }
        }}
      >
        {route.label}
      </Button>

      {/* 选中状态下的动画下划线 */}
      <AnimatePresence>
        {active && (
          <motion.div
            layoutId="navbar-indicator"
            initial={{ opacity: 0, width: 0 }}
            animate={{ opacity: 1, width: '100%' }}
            exit={{ opacity: 0, width: 0 }}
            transition={{
              type: 'spring',
              stiffness: 300,
              damping: 30,
              duration: 0.3
            }}
            style={{
              position: 'absolute',
              bottom: '8px',
              left: '0',
              height: '3px',
              borderRadius: '2px',
              backgroundColor: muiTheme.palette.primary.main,
              width: '100%'
            }}
          />
        )}
      </AnimatePresence>
    </Box>
  );
};

/**
 * 移动导航链接组件
 */
const MobileNavLink: React.FC<{ route: NavRoute; active: boolean; onClick: () => void }> = ({
  route,
  active,
  onClick
}) => {
  const navigate = useNavigate();
  const muiTheme = useMuiTheme();

  // 处理点击跳转
  const handleClick = (e: React.MouseEvent) => {
    e.preventDefault();
    navigate(route.path);
    onClick(); // 关闭菜单
  };

  return (
    <ListItem disablePadding>
      <ListItemButton
        component={Link}
        to={route.path}
        onClick={handleClick}
        selected={active}
        sx={{
          borderRadius: 2,
          my: 0.5,
          '&.Mui-selected': {
            backgroundColor: (theme) => alpha(theme.palette.primary.main, 0.1),
            color: 'primary.main',
            '&::after': {
              content: '""',
              position: 'absolute',
              left: '10px',
              top: '50%',
              transform: 'translateY(-50%)',
              width: '4px',
              height: '60%',
              backgroundColor: 'primary.main',
              borderRadius: '4px'
            }
          },
          '&:hover': {
            backgroundColor: (theme) => alpha(theme.palette.primary.main, 0.05),
          }
        }}
      >
        <ListItemText
          primary={route.label}
          primaryTypographyProps={{
            fontWeight: active ? 600 : 400,
            sx: {
              color: active ? 'primary.main' : 'text.primary'
            }
          }}
        />
      </ListItemButton>
    </ListItem>
  );
};

/**
 * 主导航栏组件
 */
const Navbar: React.FC = () => {
  const { t } = useTranslation();
  const location = useLocation();
  const [mobileOpen, setMobileOpen] = useState(false);
  const { theme } = useTheme();
  const muiTheme = useMuiTheme();
  const [scrolled, setScrolled] = useState(false);

  // 使用MUI的useScrollTrigger检测滚动
  const scrollTrigger = useScrollTrigger({
    disableHysteresis: true,
    threshold: 50,
  });

  // 监听滚动事件
  useEffect(() => {
    const handleScroll = () => {
      const offset = window.scrollY;
      if (offset > 50) {
        setScrolled(true);
      } else {
        setScrolled(false);
      }
    };

    window.addEventListener('scroll', handleScroll);
    return () => {
      window.removeEventListener('scroll', handleScroll);
    };
  }, []);

  // 构建导航路由
  const routes: NavRoute[] = [
    { path: '/', label: t('header.home') },
    { path: '/about', label: t('header.about') },
    { path: '/skills', label: t('header.skills') },
    { path: '/projects', label: t('header.projects') },
    { path: '/education', label: t('header.education') },
    { path: '/contact', label: t('header.contact') },
  ];

  // 处理侧边菜单开关
  const handleDrawerToggle = () => {
    setMobileOpen(!mobileOpen);
  };

  // 判断当前激活的路由
  const isActive = (path: string) => {
    // 首页特殊处理
    if (path === '/' && location.pathname === '/') {
      return true;
    }
    // 其他页面
    return path !== '/' && location.pathname.startsWith(path);
  };

  return (
    <>
      <motion.div
        initial={{ y: -100, opacity: 0 }}
        animate={{
          y: 0,
          opacity: 1,
          transition: { duration: 0.5, ease: "easeOut" }
        }}
        style={{
          position: 'fixed',
          top: 0,
          left: 0,
          right: 0,
          zIndex: 1100
        }}
      >
        <AppBar
          position="static"
          color="transparent"
          elevation={scrolled ? 2 : 0}
          sx={{
            backgroundColor: scrolled
              ? theme === 'dark'
                ? alpha(muiTheme.palette.background.paper, 0.9)
                : alpha(muiTheme.palette.background.default, 0.9)
              : 'transparent',
            backdropFilter: 'blur(10px)',
            borderBottom: scrolled
              ? `1px solid ${alpha(
                  theme === 'dark'
                    ? muiTheme.palette.divider
                    : muiTheme.palette.divider,
                  0.1
                )}`
              : 'none',
            transition: 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)',
            boxShadow: scrolled ? '0 4px 20px rgba(0,0,0,0.08)' : 'none',
          }}
        >
          <Container maxWidth="lg">
            <Toolbar disableGutters sx={{
              py: scrolled ? 1 : 1.5,
              transition: 'all 0.3s ease'
            }}>
              {/* Logo */}
              <Box sx={{ flexGrow: 0, mr: 2 }}>
                <Logo />
              </Box>

              {/* 桌面导航 */}
              <Box
                sx={{
                  flexGrow: 1,
                  display: { xs: 'none', md: 'flex' },
                  justifyContent: 'center',
                }}
              >
                {routes.map((route) => (
                  <NavLink
                    key={route.path}
                    route={route}
                    active={isActive(route.path)}
                  />
                ))}
              </Box>

              {/* 导航右侧功能区 */}
              <Box sx={{ display: 'flex', alignItems: 'center' }}>
                <ThemeToggle />

                <Box sx={{ ml: 2, display: { xs: 'none', md: 'block' } }}>
                  <LanguageSelector />
                </Box>

                {/* 移动端菜单按钮 */}
                <Box sx={{ display: { xs: 'flex', md: 'none' }, ml: 1 }}>
                  <IconButton
                    aria-label="Open navigation menu"
                    onClick={handleDrawerToggle}
                    size="large"
                    edge="end"
                    sx={{
                      color: 'text.primary',
                      border: theme === 'dark'
                        ? '1px solid rgba(255,255,255,0.1)'
                        : '1px solid rgba(0,0,0,0.05)',
                      borderRadius: '12px',
                    }}
                  >
                    <FiMenu />
                  </IconButton>
                </Box>
              </Box>
            </Toolbar>
          </Container>
        </AppBar>
      </motion.div>

      {/* 移动端侧边菜单 */}
      <Drawer
        anchor="right"
        open={mobileOpen}
        onClose={handleDrawerToggle}
        PaperProps={{
          sx: {
            width: '75%',
            maxWidth: '320px',
            borderTopLeftRadius: '16px',
            borderBottomLeftRadius: '16px',
            px: 2,
          },
        }}
        ModalProps={{
          keepMounted: true, // 保持DOM中以提高性能
        }}
      >
        <Box sx={{ py: 3, display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
          <Logo />
          <IconButton
            onClick={handleDrawerToggle}
            sx={{
              borderRadius: '12px',
              backgroundColor: alpha(muiTheme.palette.primary.main, 0.05),
              '&:hover': {
                backgroundColor: alpha(muiTheme.palette.primary.main, 0.1),
              },
            }}
          >
            <FiX />
          </IconButton>
        </Box>

        <Divider sx={{ mb: 2 }} />

        <List sx={{ py: 1 }}>
          {routes.map((route) => (
            <MobileNavLink
              key={route.path}
              route={route}
              active={isActive(route.path)}
              onClick={handleDrawerToggle}
            />
          ))}
        </List>

        <Box sx={{ mt: 4, display: 'flex', justifyContent: 'center' }}>
          <LanguageSelector />
        </Box>
      </Drawer>

      {/* 占位符，避免内容被导航栏覆盖 */}
      <Toolbar sx={{ mb: 2 }} />
    </>
  );
};

export default Navbar;
